    color:#cfd8dc;
    font-style:italic;
    margin-top:10px;
}

main{
    max-width:900px;
    margin:auto;
    padding:40px 20px;
}

section{
    background:rgba(255,255,255,.05);
    margin:25px 0;
    padding:25px;
    border-radius:12px;
}

h2{
    color:#ffd166;
}

blockquote{
    border-left:4px solid #ffd166;
    padding-left:15px;
    color:#eeeeee;
    font-style:italic;
}

table{
    width:100%;
    border-collapse:collapse;
}

th,td{
    border-bottom:1px solid #444;
