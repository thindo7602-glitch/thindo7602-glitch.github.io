<title>Hoàng tử bé</title>

<style>
body{
    margin:0;
    font-family:Georgia,"Times New Roman",serif;
    background:#081426;
    color:#f5f5f5;
    line-height:1.8;
}

header{
    padding:80px 20px;
    text-align:center;
    background:linear-gradient(#102542,#081426);
}

h1{
    font-size:64px;
    margin:0;
    color:#ffd166;
}

